# Primary Database
DB_HOST=localhost
DB_NAME=ml_branch_asset_depreciation
DB_USER=root
DB_PASS=Password1

# Secondary Database (optional)
DB2_HOST=localhost
DB2_NAME=masterdata
DB2_USER=root
DB2_PASS=Password1

# Application
BASE_URL=http://localhost/ml-branch-asset-depreciation

# Windows Task Scheduler / XAMPP defaults
PHP_BINARY=C:\xampp\php\php.exe
TASK_SCHEDULER_WORKING_DIR=C:\xampp\htdocs\ml-branch-asset-depreciation
TASK_SCHEDULER_RUN_TIME=07:00
TASK_NAME=ML Branch Daily Depreciation